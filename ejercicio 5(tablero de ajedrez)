int cantx = 10;
int canty = 10;
void setup() {
size(500,500);
}

void draw() {


int i=0,j=0;

int cant=0;
for(i=0;i<canty;i++){
 
  for(j=0;j<cantx;j++){
  cant++;
    if(cant%2==0 ){
    fill(0,0,0);
  
    }
    else{
      fill(255,255,255);
    }

    rect(j*width/cantx,i*height/canty,width/cantx,height/canty);
  }
  cant++;
    

  
}
 
}
