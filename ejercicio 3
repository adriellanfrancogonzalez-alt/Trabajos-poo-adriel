void setup(){
 size(400,400);
 
   
}

void draw(){
 float w=width, h=height;
 
 

 
 if(mousePressed)
 miProcedimiento(mouseX,mouseY,width,height);
 else
  background(100,200,300);

 
 }
 
 
 miProcedimiento(float mouseX,float mouseY, float w,float h){
 float sh=w/3;    //tamaño cuadrado
  square(mouseX-sh/2,mouseY-sh/2,sh); //cuadrado responsive
 
  float cw=w/4;                  //tamañno circulo
circle(mouseX-cw/2,mouseY-cw/2,cw); //circulo responsive

fill(255,0,0);}


  
