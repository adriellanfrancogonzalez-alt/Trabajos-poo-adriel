void setup(){
 size(400,400);
 
   
}

void draw(){

 
 

 
 if(mousePressed){
 miProcedimiento(mouseX*2,mouseY*2,width,height);
 }
 else
  background(100,200,300);

 
 }
 
 
 void miProcedimiento(float X,float Y, float w,float h){

 background(200,100,700);
     //tamaño cuadrado
  circle(X/2,Y/2-w/4,w/4); //cuadrado responsive
 
                 //tamañno circulo
circle(X/2,Y/2,w/4); //circulo responsive

fill(255,0,0);


}


  
